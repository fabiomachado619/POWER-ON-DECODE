# Application
NODE_ENV=development
APP_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/power_on_decode?schema=public"

# Authentication
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
SESSION_COOKIE_NAME="podt_session"
SESSION_MAX_AGE=604800

# Payment webhook security
PAYMENT_WEBHOOK_SECRET="change-this-webhook-secret-in-production"

# Product mapping (external_product_id -> module slug)
# Format: comma-separated pairs productId:moduleSlug
PAYMENT_PRODUCT_MAP="prod_ssangyong:ssangyong,prod_volkswagen:volkswagen,prod_fiat:fiat,prod_jeep_scanner:jeep-fiat-scanner"

# Seed admin user (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@powerondecode.local"
SEED_ADMIN_PASSWORD="Admin@123456"
SEED_ADMIN_NAME="Administrador"

# Cron job security (access expiration notifications)
CRON_SECRET="change-this-cron-secret-in-production"

# SMTP (fallback when not configured in admin panel)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_NAME="Power On Decode"
SMTP_FROM_EMAIL="noreply@powerondecode.local"
SMTP_SECURE=false
