generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  passwordHash       String              @map("password_hash")
  role               String              @default("customer")
  createdAt          DateTime            @default(now()) @map("created_at")
  userModules        UserModule[]
  decodeLogs         DecodeLog[]
  passwordResetTokens PasswordResetToken[]
  adminAuditLogs     AdminAuditLog[]     @relation("AdminAuditLogs")
  emailCampaignsCreated EmailCampaign[]  @relation("CampaignCreator")
  webhookConfigsCreated WebhookConfig[] @relation("WebhookConfigCreator")

  @@map("users")
}

model Module {
  id               String            @id @default(cuid())
  slug             String            @unique
  name             String
  description      String
  active           Boolean           @default(true)
  userModules      UserModule[]
  decodeProcedures DecodeProcedure[]
  tools            Tool[]

  @@map("modules")
}

model UserModule {
  id                  String               @id @default(cuid())
  userId              String               @map("user_id")
  moduleId            String               @map("module_id")
  status              String               @default("active")
  accessStatus        String               @default("active") @map("access_status")
  startsAt            DateTime?            @map("starts_at")
  expiresAt           DateTime?            @map("expires_at")
  source              String?
  sourcePayment       String?              @map("source_payment")
  externalProductId   String?              @map("external_product_id")
  notes               String?
  createdAt           DateTime             @default(now()) @map("created_at")
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  module              Module               @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  accessNotifications AccessNotification[]

  @@unique([userId, moduleId])
  @@map("user_modules")
}

model Manufacturer {
  id           String  @id @default(cuid())
  name         String
  slug         String  @unique
  logoUrl      String? @map("logo_url")
  displayOrder Int     @default(0) @map("display_order")
  active       Boolean @default(true)
  tools        Tool[]

  @@map("manufacturers")
}

model ToolCategory {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String
  icon         String?
  displayOrder Int      @default(0) @map("display_order")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  tools        Tool[]

  @@map("tool_categories")
}

model Tool {
  id                String           @id @default(cuid())
  categoryId        String           @map("category_id")
  manufacturerId    String           @map("manufacturer_id")
  moduleId          String           @map("module_id")
  decodeProcedureId String?          @unique @map("decode_procedure_id")
  slug              String
  displayName       String?          @map("display_name")
  name              String
  description       String
  longDescription   String?          @map("long_description")
  type              String
  ecuName           String?          @map("ecu_name")
  eepromType        String?          @map("eeprom_type")
  coverImageUrl     String?          @map("cover_image_url")
  purchaseUrl       String?          @map("purchase_url")
  toolRoute         String?          @map("tool_route")
  buttonText        String?          @map("button_text")
  displayOrder      Int              @default(0) @map("display_order")
  featured          Boolean          @default(false)
  visible           Boolean          @default(true)
  showInStore       Boolean          @default(true) @map("show_in_store")
  isImplemented     Boolean          @default(false) @map("is_implemented")
  active            Boolean          @default(true)
  category          ToolCategory     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  manufacturer      Manufacturer     @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  module            Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  decodeProcedure   DecodeProcedure? @relation(fields: [decodeProcedureId], references: [id], onDelete: SetNull)

  @@unique([moduleId, slug])
  @@map("tools")
}

model DecodeProcedure {
  id            String      @id @default(cuid())
  moduleId      String      @map("module_id")
  slug          String
  name          String
  ecuName       String      @map("ecu_name")
  eepromType    String      @map("eeprom_type")
  expectedSize  Int         @map("expected_size")
  offsetHex     String      @map("offset_hex")
  writeBytesHex String      @map("write_bytes_hex")
  active        Boolean     @default(true)
  module        Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  decodeLogs    DecodeLog[]
  tool          Tool?

  @@unique([moduleId, slug])
  @@map("decode_procedures")
}

model DecodeLog {
  id               String           @id @default(cuid())
  userId           String           @map("user_id")
  procedureId      String?          @map("procedure_id")
  toolSlug         String?          @map("tool_slug")
  technicalVersion String?          @map("technical_version")
  category         String?
  originalFilename String           @map("original_filename")
  fileSize         Int              @map("file_size")
  offsetApplied    String           @map("offset_applied")
  status           String
  errorMessage     String?          @map("error_message")
  createdAt        DateTime         @default(now()) @map("created_at")
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  procedure        DecodeProcedure? @relation(fields: [procedureId], references: [id], onDelete: SetNull)

  @@map("decode_logs")
}

model PaymentEvent {
  id                String   @id @default(cuid())
  provider          String
  externalEventId   String   @map("external_event_id")
  externalProductId String?  @map("external_product_id")
  customerEmail     String?  @map("customer_email")
  customerName      String?  @map("customer_name")
  productName       String?  @map("product_name")
  toolSlug          String?  @map("tool_slug")
  toolsReleased     String?  @map("tools_released")
  webhookConfigId   String?  @map("webhook_config_id")
  emailSent         Boolean  @default(false) @map("email_sent")
  status            String
  processMessage    String?  @map("process_message")
  rawPayload        Json     @map("raw_payload")
  createdAt         DateTime @default(now()) @map("created_at")
  webhookConfig     WebhookConfig? @relation(fields: [webhookConfigId], references: [id], onDelete: SetNull)

  @@unique([provider, externalEventId])
  @@map("payment_events")
}

model ProductMapping {
  id                String   @id @default(cuid())
  externalProductId String   @unique @map("external_product_id")
  toolSlug          String   @map("tool_slug")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("product_mappings")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model EmailSettings {
  id            String   @id @default("default")
  smtpHost      String   @map("smtp_host")
  smtpPort      Int      @map("smtp_port")
  smtpUser      String   @map("smtp_user")
  smtpPassword  String   @map("smtp_password")
  smtpFromName  String   @map("smtp_from_name")
  smtpFromEmail String   @map("smtp_from_email")
  smtpSecure    Boolean  @default(false) @map("smtp_secure")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("email_settings")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  subject   String
  bodyHtml  String   @map("body_html")
  bodyText  String   @map("body_text")
  active    Boolean  @default(true)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}

model AccessNotification {
  id           String     @id @default(cuid())
  userModuleId String     @map("user_module_id")
  type         String
  sentAt       DateTime   @default(now()) @map("sent_at")
  userModule   UserModule @relation(fields: [userModuleId], references: [id], onDelete: Cascade)

  @@unique([userModuleId, type])
  @@map("access_notifications")
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String   @map("admin_user_id")
  action      String
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  adminUser   User     @relation("AdminAuditLogs", fields: [adminUserId], references: [id], onDelete: Cascade)

  @@map("admin_audit_logs")
}

model EmailCampaign {
  id              String                   @id @default(cuid())
  title           String
  subject         String
  htmlContent     String                   @map("html_content")
  textContent     String                   @map("text_content")
  audienceType    String                   @map("audience_type")
  categorySlug    String?                  @map("category_slug")
  toolSlug        String?                  @map("tool_slug")
  status          String                   @default("draft")
  totalRecipients Int                      @default(0) @map("total_recipients")
  sentCount       Int                      @default(0) @map("sent_count")
  failedCount     Int                      @default(0) @map("failed_count")
  createdById     String                   @map("created_by")
  createdAt       DateTime                 @default(now()) @map("created_at")
  sentAt          DateTime?                @map("sent_at")
  createdBy       User                     @relation("CampaignCreator", fields: [createdById], references: [id], onDelete: Cascade)
  recipients      EmailCampaignRecipient[]

  @@map("email_campaigns")
}

model EmailCampaignRecipient {
  id           String        @id @default(cuid())
  campaignId   String        @map("campaign_id")
  userId       String?       @map("user_id")
  email        String
  status       String        @default("pending")
  errorMessage String?       @map("error_message")
  sentAt       DateTime?     @map("sent_at")
  campaign     EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, email])
  @@map("email_campaign_recipients")
}

model PwaSettings {
  id          String   @id @default("default")
  appName     String   @default("Power On Decode") @map("app_name")
  shortName   String   @default("Decode") @map("short_name")
  description String   @default("Ferramentas técnicas automotivas para decode, reset, odômetro e checksum.")
  themeColor  String   @default("#10B981") @map("theme_color")
  backgroundColor String @default("#F5F7FA") @map("background_color")
  promptText  String   @default("Instale o Power On Decode no seu computador para acessar suas ferramentas com mais facilidade.") @map("prompt_text")
  active      Boolean  @default(true)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("pwa_settings")
}

model WebhookConfig {
  id            String              @id @default(cuid())
  name          String
  slug          String              @unique
  token         String              @unique
  urlPath       String              @unique @map("url_path")
  active        Boolean             @default(true)
  description   String?
  createdById   String              @map("created_by")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  createdBy     User                @relation("WebhookConfigCreator", fields: [createdById], references: [id], onDelete: Cascade)
  tools         WebhookConfigTool[]
  paymentEvents PaymentEvent[]

  @@map("webhook_configs")
}

model WebhookConfigTool {
  id              String        @id @default(cuid())
  webhookConfigId String        @map("webhook_config_id")
  toolSlug        String        @map("tool_slug")
  createdAt       DateTime      @default(now()) @map("created_at")
  webhookConfig   WebhookConfig @relation(fields: [webhookConfigId], references: [id], onDelete: Cascade)

  @@unique([webhookConfigId, toolSlug])
  @@map("webhook_config_tools")
}
